PORT=8080

# AWS RDS PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/easyfishdb
SPRING_DATASOURCE_USERNAME=your_rds_username
SPRING_DATASOURCE_PASSWORD=your_rds_password
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# AWS S3 + CloudFront
AWS_S3_ENABLED=true
AWS_S3_REGION=ap-south-1
AWS_S3_BUCKET=easyfish-prod-images
AWS_S3_PUBLIC_URL=https://your-cloudfront-domain.cloudfront.net
AWS_ACCESS_KEY_ID=your_iam_access_key
AWS_SECRET_ACCESS_KEY=your_iam_secret_key
AWS_S3_PRESIGN_EXPIRY_SECONDS=900

# JWT
JWT_SECRET=change-this-to-a-long-secure-production-secret-at-least-32-characters
JWT_EXPIRATION=86400000

# Mail / OTP
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your_email@gmail.com
SPRING_MAIL_PASSWORD=your_app_password
FAST2SMS_API_KEY=your_fast2sms_api_key
FAST2SMS_ROUTE=otp
FAST2SMS_SENDER_ID=

# Razorpay
RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Frontend admin/store environment
REACT_APP_API_BASE_URL=https://your-aws-backend-domain.com

RAZORPAY_WEBHOOK_SECRET=
FAST2SMS_TEMPLATE_ID=

GOOGLE_CLIENT_ID=427085224731-6nquorqcu3hluhs8ismrltikenk106fp.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=PUT_YOUR_GOOGLE_CLIENT_SECRET_HERE
